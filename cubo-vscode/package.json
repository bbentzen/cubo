{
  "name": "cubo-vscode",
  "displayName": "Cubo Language Support",
  "description": "Syntax highlighting and diagnostics for the Cubo proof assistant",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "cubo",
        "aliases": [
          "Cubo",
          "cubo"
        ],
        "extensions": [
          ".cubo"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cubo",
        "scopeName": "source.cubo",
        "path": "./syntaxes/cubo.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Cubo Configuration",
      "properties": {
        "cubo.executablePath": {
          "type": "string",
          "default": "cubo",
          "description": "Path to the cubo compiler binary (assumes global PATH if left default)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.125.0",
    "typescript": "^6.0.3"
  }
}

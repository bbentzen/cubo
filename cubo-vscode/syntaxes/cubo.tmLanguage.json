{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Cubo",
  "patterns": [
    { "include": "#comments-block" },
    { "include": "#keywords" }
  ],
  "repository": {
    "keywords": {
      "match": "\\b(definition|def|theorem|thm|lemma|lem|import|print|universe)\\b",
      "name": "keyword.control.cubo"
    },
    "comments-block": {
      "begin": "/\\*",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.comment.cubo" }
      },
      "end": "\\*/",
      "endCaptures": {
        "0": { "name": "punctuation.definition.comment.cubo" }
      },
      "name": "comment.block.cubo"
    }
  },
  "scopeName": "source.cubo"
}
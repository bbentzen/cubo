import ./function.cube
import ./path.cube

/* Natural numbers */
 
def pred
⊢ nat → nat :=
λ n, natrec n 0 (λ k _, k)
 
def add
⊢ nat → nat → nat :=
λ m n, natrec n m (λ k f, succ f)

def mult 
⊢ nat → nat → nat := 
λ m n, natrec n 0 (λ k f, (natrec f m (λ k, λ g, succ g)))
 
/* Numerical equations */
 
def add_zero (m : nat)
⊢ path nat ((add 0) m) m :=
natrec m (<_> 0) (λ n p , <i> succ (p @ i))

def succ_iff_eq {n m : nat}
⊢ path nat (succ n) (succ m) ↔ path nat n m :=
(λ p, <i> natrec (p @ i) n (λ k _, k), λ p, <i> succ (p @ i))

def succ_to_eq {n m : nat}
⊢ path nat (succ n) (succ m) → path nat n m :=
fst succ_iff_eq

def eq_to_succ {n m : nat}
⊢ path nat n m → path nat (succ n) (succ m) :=
snd succ_iff_eq

def pred_succ {n : nat}
⊢ path nat (pred (succ n)) n :=
<_> n
 
def succ_pred {n : nat} (w : Σ (k : nat) path nat (succ k) n)
⊢ path nat (succ (pred n)) n :=
coe i0 i1 (λ i, path nat (succ (pred (snd w @ i))) (snd w @ i)) (<_> succ (fst w)) 
 
def nat_neq {n : nat}
⊢ ¬ path nat 0 (succ n) :=
λ p, coe i0 i1 (λ i, natrec (p @ i) unit (λ _ _, void)) ()

def nat_neq' {n : nat}
⊢ ¬ path nat (succ n) 0 :=
λ p, coe i1 i0 (λ i, natrec (p @ i) unit (λ _ _, void)) ()

/* Basic arithmetical laws */

def add_assoc (m n k : ℕ)
⊢ path ℕ (add (add m n) k) (add m (add n k)) :=
natrec k (<_> add m n) (λ k ih, eq_to_succ ih)

def add_comm_zero (m : ℕ)
⊢ path ℕ m (add 0 m) :=
natrec m (<_> 0) (λ k ih, eq_to_succ ih) 

def add_comm_succ (l n : ℕ)
⊢ path ℕ (succ (add l n)) (add (succ l) n) :=
natrec n (<_> succ l) (λ _ ih, eq_to_succ ih)

def add_comm (m n : ℕ)
⊢ path ℕ (add m n) (add n m) :=
natrec m (add_comm_zero n) (λ k ih, 
  path_trans (eq_to_succ ih) (add_comm_succ k n) )

def add_left {m n : ℕ} (k : ℕ)
⊢ path ℕ m n → path ℕ (add k m) (add k n) :=
λ p, <i> add k (p @ i)

def add_right {m n : ℕ} (k : ℕ)
⊢ path ℕ m n → path ℕ (add m k) (add n k) :=
λ p, <i> add (p @ i) k

def add_two {m n k l : ℕ}
⊢ path ℕ m n → path ℕ k l → path ℕ (add m k) (add n l) :=
λ p q, <i> add (p @ i) (q @ i)

def add_inj {m n k : ℕ}
⊢ path ℕ (add m k) (add n k) → path ℕ m n :=
natrec k id (λ i ih p, ih (succ_to_eq p))

def add_comm2 (m n k : ℕ) /* takes about 2.5 seconds */
⊢ path ℕ (add (add m n) k) (add (add m k) n) :=
(add_assoc m n k) · (add_left m (add_comm n k)) · (add_assoc m n k)⁻¹

def leq (m n : ℕ)
⊢ type 1 :=
Σ (i : ℕ) path ℕ (add m i) n

/* Code-decode */

def nat_code (n m : nat)
⊢ type 1 :=
natrec n 
  (natrec m (path nat 0 0) (λ _ _, void)) 
  (λ n' C, natrec m void (λ m' _, path nat succ n' succ m'))
 
def nat_eq {n m : nat}
⊢ path nat n m ↔ nat_code n m :=
natrec n
 (natrec m id_iff_id (λ k _, (nat_neq, absurd)))
 (λ k _, natrec m (nat_neq', absurd) (λ k' _, id_iff_id))


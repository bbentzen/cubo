{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Cubicle",
  "patterns": [
    { "include": "#comments-block" },
    { "include": "#keywords" }
  ],
  "repository": {
    "keywords": {
      "match": "\\b(definition|def|theorem|thm|lemma|lem|import|infer|eval|print|universe)\\b",
      "name": "keyword.control.cubicle"
    },
    "comments-block": {
      "begin": "/\\*",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.comment.cubicle" }
      },
      "end": "\\*/",
      "endCaptures": {
        "0": { "name": "punctuation.definition.comment.cubicle" }
      },
      "name": "comment.block.cubicle"
    }
  },
  "scopeName": "source.cubicle"
}